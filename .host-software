# .host-software — the Where room: each component a bare store with worktrees.
# Tracked recipe; the trees under software/ are local, gitignored, materialised by
# `host-lifecycle software --materialize .` and audited by `--check`.

# The gating tool. Consumed (referenced), not authored here, so it carries the
# commit hook dispatch and the built binary it installs, but no build recipe: the
# host does not claim to reproduce host-lint, only to pin and install it.
[software "host-lint"]
    url      = https://github.com/connollydavid/host-lint.git
    pin      = 78804cd9deb5daa279705c6f5cd9be12ccfd6765
    branch   = main
    hooks    = pre-commit
    artifact = target/release/host-lint 03c61c5aab2129d488a921a30ef2f4cd4a99e8d40bc5734ad5101b508806adae
    repro-exempt = call/0002

# The software under development. Migrated (pre-existing), recorded as a source pin
# on its canonical branch with no deploy artifact, so no reproducible build is
# claimed yet (add a recipe + repro-exempt, or a real artifact, before shipping).
[software "udpspeeder-simd"]
    url    = https://github.com/connollydavid/UDPspeeder-simd.git
    pin    = c2b37590ca2efd6d3564c11ef5fe3a2c8031bda9
    branch = branch_libev

# A fork of the OpenWrt packages feed (Makefiles/shell/C). Migrated (pre-existing),
# recorded as a source pin on its canonical branch (master) with no deploy artifact:
# it is a package-build-recipe feed layered on an OpenWrt buildroot, not a built
# artifact, so no reproducible build is claimed here. GPL-2.0 in its own tree.
[software "packages"]
    url    = https://github.com/connollydavid/packages.git
    pin    = 1d40ad929ad45cfbdf547996d0ba2379d9765172
    branch = master

# OpenWrt upstream (the buildroot). Embedded as a source pin on its canonical branch
# (main; the master branch mirrors the same commit) so the x86_64 SDK can be built from
# source and the udpspeeder-simd feed package validated against the snapshot SDK the
# OpenWrt CI uses. GPL-2.0 in its own tree. No artifact recorded here: the SDK build is a
# separate, heavy step, not a reproducible-build claim of this host.
[software "openwrt"]
    url    = https://github.com/openwrt/openwrt.git
    pin    = 62e7565f0e1e88e5fc8d038f09cb38ffd583bbed
    branch = main
